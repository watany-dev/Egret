{
  "family": "smoke-multi",
  "taskRoleArn": "arn:aws:iam::123456789012:role/ecsTaskRole",
  "executionRoleArn": "arn:aws:iam::123456789012:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "taskDefinitionArn": "arn:aws:ecs:us-east-1:123456789012:task-definition/smoke-multi:1",
  "revision": 1,
  "status": "ACTIVE",
  "compatibilities": ["EC2", "FARGATE"],
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "egret-test:latest",
      "essential": true,
      "cpu": 128,
      "memory": 256,
      "command": ["/bin/sh", "-c", "echo ready > /tmp/healthy && echo 'backend started' && sleep 300"],
      "portMappings": [],
      "environment": [
        { "name": "ROLE", "value": "backend" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "test -f /tmp/healthy"],
        "interval": 5,
        "timeout": 3,
        "retries": 3,
        "startPeriod": 2
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/smoke-multi",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    },
    {
      "name": "frontend",
      "image": "egret-test:latest",
      "essential": true,
      "cpu": 256,
      "memory": 512,
      "command": ["/bin/sh", "-c", "echo 'frontend started (backend healthy)' && sleep 300"],
      "portMappings": [],
      "environment": [
        { "name": "ROLE", "value": "frontend" },
        { "name": "BACKEND_HOST", "value": "backend" }
      ],
      "dependsOn": [
        { "containerName": "backend", "condition": "HEALTHY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/smoke-multi",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ],
  "volumes": [],
  "placementConstraints": [],
  "tags": [
    { "key": "Pattern", "value": "multi-container" }
  ]
}
