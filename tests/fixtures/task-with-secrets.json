{
  "family": "app-with-secrets",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "myapp:latest",
      "essential": true,
      "environment": [
        { "name": "APP_ENV", "value": "local" }
      ],
      "secrets": [
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789:secret:prod/db-password" },
        { "name": "API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789:secret:prod/api-key" }
      ],
      "portMappings": [
        { "containerPort": 8080, "hostPort": 8080 }
      ]
    }
  ]
}
