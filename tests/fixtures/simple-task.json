{
  "family": "simple-web",
  "containerDefinitions": [
    {
      "name": "nginx",
      "image": "nginx:alpine",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NGINX_HOST",
          "value": "localhost"
        }
      ],
      "cpu": 256,
      "memory": 512
    }
  ]
}
